# File: .env.example
# --- Project Configuration ---
PROJECT_NAME=mia-iac-auto-gke-gcp-foundation
ENVIRONMENT=dev # dev, stage, prod

# --- GCP Configuration ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# --- GKE Architecture ---
GKE_CLUSTER_NAME=mia-gke-cluster
SHARED_VPC_HOST_PROJECT=your-host-project-id

# --- SRE & Observability ---
# Enable automated SLO tracking and incident response simulations
ENABLE_SRE_MONITORING=true
LOGGING_SINK_DESTINATION=bigquery

# --- Security & Policy-as-Code ---
# Enforce GCP Org Policy constraints and Sentinel/OPA checks
HARDENING_ENFORCED=true
COMPLIANCE_FRAMEWORK=NIST-800-53
USE_WORKLOAD_IDENTITY=true

# --- AI Remediation ---
# Specify Vertex AI settings for the automated compliance agent
AI_PROVIDER=vertex_ai
AI_MODEL_ID=gemini-1.5-flash


